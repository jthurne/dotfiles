#!/usr/bin/env bash
#
# Add an existing extension by cloning its repo into extensions/.
#
# Usage: scripts/add-extension <name> [git-url]
#   e.g. scripts/add-extension work-private
#        scripts/add-extension work-private git@github.com:jthurne/dotfiles-work-private.git
#
# If no URL is given, assumes git@github.com:jthurne/dotfiles-<name>.git

set -e

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

if [ -z "$1" ]; then
  echo "Usage: scripts/add-extension <name> [git-url]"
  echo "  e.g. scripts/add-extension work-private"
  exit 1
fi

name="$1"
url="${2:-git@github.com:jthurne/dotfiles-$name.git}"
ext_dir="$DOTFILES_ROOT/extensions/$name"

if [ -d "$ext_dir" ]; then
  echo "Error: extension '$name' already exists at $ext_dir"
  exit 1
fi

echo "Cloning '$url' into extensions/$name..."
git clone "$url" "$ext_dir"

echo ""
echo "Extension '$name' added at $ext_dir"
echo ""
echo "Run scripts/install-dotfiles to symlink new dotfiles."
echo "Run scripts/install-packages to run any install.sh scripts."
