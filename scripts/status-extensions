#!/usr/bin/env bash
#
# Show git status summary for all extensions.
#
# Usage: scripts/status-extensions

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

ext_base="$DOTFILES_ROOT/extensions"

if [ ! -d "$ext_base" ]; then
  echo "No extensions directory found."
  exit 0
fi

for ext_dir in "$ext_base"/*/; do
  [ -d "$ext_dir/.git" ] || continue
  name=$(basename "$ext_dir")

  branch=$(git -C "$ext_dir" branch --show-current 2>/dev/null || echo "detached")
  ahead=$(git -C "$ext_dir" rev-list --count @{upstream}..HEAD 2>/dev/null || echo "?")
  behind=$(git -C "$ext_dir" rev-list --count HEAD..@{upstream} 2>/dev/null || echo "?")
  dirty=$(git -C "$ext_dir" status --porcelain 2>/dev/null)

  status=""
  [ "$ahead" != "0" ] && [ "$ahead" != "?" ] && status+=" ${ahead} ahead"
  [ "$behind" != "0" ] && [ "$behind" != "?" ] && status+=" ${behind} behind"
  [ -n "$dirty" ] && status+=" dirty"
  [ -z "$status" ] && status=" clean"

  echo "$name ($branch):$status"
done
