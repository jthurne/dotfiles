#!/usr/bin/env bash
#
# Manage dotfiles extensions.
#
# Usage: scripts/extensions <command> [args]
#
# Commands:
#   create <name>          Initialize a new extension repo and create it on GitHub
#   add <name> [git-url]   Clone an existing extension repo
#   remove <name>          Remove a local extension (preserves the remote repo)
#   status                 Show git status summary for all extensions
#   update                 Pull latest changes for all extensions
#   push                   Push all extensions that have unpushed commits

set -e

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)
EXT_BASE="$DOTFILES_ROOT/extensions"

run_gh() {
  if [ -n "$GH_TOKEN" ]; then
    gh "$@"
  else
    op plugin run -- gh "$@"
  fi
}

usage() {
  echo "Usage: scripts/extensions <command> [args]"
  echo ""
  echo "Commands:"
  echo "  create <name> [--org <org>] [--repo <repo-name>]"
  echo "                         Initialize a new extension repo and create it on GitHub"
  echo "                         (defaults to org=jthurne, repo=dotfiles-<name>)"
  echo "  add <name> [git-url]   Clone an existing extension repo"
  echo "                         (defaults to git@github.com:jthurne/dotfiles-<name>.git)"
  echo "  remove <name>          Remove a local extension (preserves the remote repo)"
  echo "  status                 Show git status summary for all extensions"
  echo "  update                 Pull latest changes for all extensions"
  echo "  push                   Push all extensions that have unpushed commits"
  exit 1
}

cmd_create() {
  local name="" org="jthurne" repo_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --org)  org="$2"; shift 2 ;;
      --repo) repo_name="$2"; shift 2 ;;
      -*)     echo "Unknown flag: $1"; exit 1 ;;
      *)      name="$1"; shift ;;
    esac
  done

  if [ -z "$name" ]; then
    echo "Usage: scripts/extensions create <name> [--org <org>] [--repo <repo-name>]"
    exit 1
  fi

  repo_name="${repo_name:-dotfiles-$name}"
  local ext_dir="$EXT_BASE/$name"

  if [ -d "$ext_dir" ]; then
    echo "Error: extension '$name' already exists at $ext_dir"
    exit 1
  fi

  echo "Creating extension '$name'..."

  mkdir -p "$ext_dir"
  git -C "$ext_dir" init

  cat > "$ext_dir/README.md" << EOF
# $repo_name

Dotfiles extension: $name

Part of [dotfiles](https://github.com/$org/dotfiles). See the main repo for conventions.
EOF

  git -C "$ext_dir" add -A
  git -C "$ext_dir" commit -m "Initial commit"

  echo ""
  echo "Creating GitHub repo '$org/$repo_name'..."
  run_gh repo create "$org/$repo_name" --private --source="$ext_dir" --remote=origin --push

  echo ""
  echo "Extension '$name' created at $ext_dir"
  echo "Remote: git@github.com:$org/$repo_name.git"
}

cmd_add() {
  if [ -z "$1" ]; then
    echo "Usage: scripts/extensions add <name> [git-url]"
    exit 1
  fi

  local name="$1"
  local url="${2:-git@github.com:jthurne/dotfiles-$name.git}"
  local ext_dir="$EXT_BASE/$name"

  if [ -d "$ext_dir" ]; then
    echo "Error: extension '$name' already exists at $ext_dir"
    exit 1
  fi

  echo "Cloning '$url' into extensions/$name..."
  git clone "$url" "$ext_dir"

  echo ""
  echo "Extension '$name' added at $ext_dir"
  echo ""
  echo "Run scripts/install-dotfiles to symlink new dotfiles."
  echo "Run scripts/install-packages to run any install.sh scripts."
}

cmd_remove() {
  if [ -z "$1" ]; then
    echo "Usage: scripts/extensions remove <name>"
    exit 1
  fi

  local name="$1"
  local ext_dir="$EXT_BASE/$name"

  if [ ! -d "$ext_dir" ]; then
    echo "Error: extension '$name' not found at $ext_dir"
    exit 1
  fi

  # Warn about uncommitted or unpushed work
  local dirty ahead
  dirty=$(git -C "$ext_dir" status --porcelain 2>/dev/null)
  ahead=$(git -C "$ext_dir" rev-list --count @{upstream}..HEAD 2>/dev/null || echo "0")

  if [ -n "$dirty" ] || [ "$ahead" -gt 0 ] 2>/dev/null; then
    echo "Warning: extension '$name' has uncommitted or unpushed changes:"
    [ -n "$dirty" ] && echo "  - uncommitted changes"
    [ "$ahead" -gt 0 ] 2>/dev/null && echo "  - $ahead unpushed commit(s)"
    echo ""
  fi

  printf "Remove extension '$name'? [y/N] "
  read -r confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "Aborted."
    exit 0
  fi

  rm -rf "$ext_dir"
  echo "Extension '$name' removed."
  echo "Re-add later with: scripts/extensions add $name"
}

cmd_status() {
  if [ ! -d "$EXT_BASE" ]; then
    echo "No extensions directory found."
    exit 0
  fi

  for ext_dir in "$EXT_BASE"/*/; do
    [ -d "$ext_dir/.git" ] || continue
    local name branch ahead behind dirty status
    name=$(basename "$ext_dir")

    branch=$(git -C "$ext_dir" branch --show-current 2>/dev/null || echo "detached")
    ahead=$(git -C "$ext_dir" rev-list --count @{upstream}..HEAD 2>/dev/null || echo "?")
    behind=$(git -C "$ext_dir" rev-list --count HEAD..@{upstream} 2>/dev/null || echo "?")
    dirty=$(git -C "$ext_dir" status --porcelain 2>/dev/null)

    status=""
    [ "$ahead" != "0" ] && [ "$ahead" != "?" ] && status+=" ${ahead} ahead"
    [ "$behind" != "0" ] && [ "$behind" != "?" ] && status+=" ${behind} behind"
    [ -n "$dirty" ] && status+=" dirty"
    [ -z "$status" ] && status=" clean"

    echo "$name ($branch):$status"
  done
}

cmd_update() {
  if [ ! -d "$EXT_BASE" ]; then
    echo "No extensions directory found."
    exit 0
  fi

  for ext_dir in "$EXT_BASE"/*/; do
    [ -d "$ext_dir/.git" ] || continue
    local name
    name=$(basename "$ext_dir")
    echo "Pulling $name..."
    git -C "$ext_dir" pull --rebase
    echo ""
  done

  echo "All extensions updated."
}

cmd_push() {
  if [ ! -d "$EXT_BASE" ]; then
    echo "No extensions directory found."
    exit 0
  fi

  for ext_dir in "$EXT_BASE"/*/; do
    [ -d "$ext_dir/.git" ] || continue
    local name ahead
    name=$(basename "$ext_dir")

    ahead=$(git -C "$ext_dir" rev-list --count @{upstream}..HEAD 2>/dev/null || echo "unknown")

    if [ "$ahead" = "unknown" ]; then
      echo "$name: no upstream configured, skipping"
    elif [ "$ahead" -gt 0 ]; then
      echo "$name: pushing $ahead commit(s)..."
      git -C "$ext_dir" push
    else
      echo "$name: up to date"
    fi
  done

  echo ""
  echo "Done."
}

command="$1"
shift || true

case "$command" in
  create) cmd_create "$@" ;;
  add)    cmd_add "$@" ;;
  remove) cmd_remove "$@" ;;
  status) cmd_status ;;
  update) cmd_update ;;
  push)   cmd_push ;;
  *)      usage ;;
esac
