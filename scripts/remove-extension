#!/usr/bin/env bash
#
# Remove a local extension. Does not delete the remote repo.
#
# Usage: scripts/remove-extension <name>
#   e.g. scripts/remove-extension work-private

set -e

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

if [ -z "$1" ]; then
  echo "Usage: scripts/remove-extension <name>"
  echo "  e.g. scripts/remove-extension work-private"
  exit 1
fi

name="$1"
ext_dir="$DOTFILES_ROOT/extensions/$name"

if [ ! -d "$ext_dir" ]; then
  echo "Error: extension '$name' not found at $ext_dir"
  exit 1
fi

# Warn about uncommitted or unpushed work
dirty=$(git -C "$ext_dir" status --porcelain 2>/dev/null)
ahead=$(git -C "$ext_dir" rev-list --count @{upstream}..HEAD 2>/dev/null || echo "0")

if [ -n "$dirty" ] || [ "$ahead" -gt 0 ] 2>/dev/null; then
  echo "Warning: extension '$name' has uncommitted or unpushed changes:"
  [ -n "$dirty" ] && echo "  - uncommitted changes"
  [ "$ahead" -gt 0 ] 2>/dev/null && echo "  - $ahead unpushed commit(s)"
  echo ""
fi

printf "Remove extension '$name'? [y/N] "
read -r confirm
if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
  echo "Aborted."
  exit 0
fi

rm -rf "$ext_dir"
echo "Extension '$name' removed."
echo "Re-add later with: scripts/add-extension $name"
